{
  "name": "claudefy",
  "version": "0.1.0",
  "description": "Sync your Claude Code environment across machines",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudefy": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kodrunhq/claudefy.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "sync",
    "cli",
    "dotfiles"
  ],
  "author": "Kodrun",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kodrunhq/claudefy/issues"
  },
  "homepage": "https://github.com/kodrunhq/claudefy#readme",
  "dependencies": {
    "age-encryption": "^0.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "deepmerge": "^4.3.1",
    "simple-git": "^3.32.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
